<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- خلفية النجوم المتحركة -->
    <com.amr3d.preview.pro.WireframeAnimView
        android:id="@+id/wireframeAnim"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- اللوجو في المنتصف -->
    <ImageView
        android:id="@+id/splashLogo"
        android:layout_width="260dp"
        android:layout_height="160dp"
        android:src="@drawable/splash_logo"
        android:scaleType="fitCenter"
        android:contentDescription="Amr Hamam 3D"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="180dp" />

    <!-- خط نيون -->
    <View
        android:id="@+id/splashGlowLine"
        android:layout_width="200dp"
        android:layout_height="2dp"
        android:background="@drawable/splash_glow_line"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="348dp" />

    <!-- مرحباً بك -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مرحباً بك"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="368dp" />

    <!-- المطور -->
    <TextView
        android:id="@+id/splashDev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تم التطوير بواسطة\nAmr Hamam 3D"
        android:textColor="#FF8A1E"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="430dp" />

    <!-- اسم التطبيق في الأسفل -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amr3D Preview Pro"
        android:textColor="#444444"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="56dp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/splashProgress"
        style="@style/SplashProgressBar"
        android:layout_width="280dp"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="32dp" />

</FrameLayout>
